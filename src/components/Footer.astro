// Get icon SVG or fallback to first letter
function getSocialIcon(iconName: string | undefined, platformName: string): string {
  if (iconName) {
    const normalizedIcon = iconName.toLowerCase().trim();
    if (socialIcons[normalizedIcon]) {
      return socialIcons[normalizedIcon];
    }
  }
  // Fallback: return first letter of platform name
  return `<span class="social-letter">${platformName.charAt(0).toUpperCase()}</span>`;
}
---

<footer class="footer">
  <div class="footer-container">
    <div class="footer-main">
      <div class="footer-brand">
        {(settings?.footer_logo || settings?.logo) ? (
          <img
            src={getAssetUrl(settings.footer_logo || settings.logo)}
            alt={settings.site_name || 'Logo'}
            class="footer-logo"
          />
        ) : (
          <span class="footer-site-name">{settings?.site_name || 'Mijn Website'}</span>
        )}

        {settings?.footer_text && (
          <div class="footer-text" set:html={settings.footer_text} />
        )}
      </div>

      {navItems.length > 0 && (
        <div class="footer-nav">
          <h4 class="footer-nav-title">Navigatie</h4>
          <ul class="footer-menu">
            {navItems.map((item) => (
              <li class="footer-menu-item">
                <a
                  href={getItemUrl(item)}
                  class="footer-menu-link"
                  target={item.open_in_new_tab ? '_blank' : undefined}
                  rel={item.open_in_new_tab ? 'noopener noreferrer' : undefined}
                >
                  {item.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      )}

      {(settings?.contact_email || settings?.contact_phone || settings?.contact_address) && (
        <div class="footer-contact">
          <h4 class="footer-nav-title">Contact</h4>
          <ul class="footer-contact-list">
            {settings.contact_email && (
              <li>
                <a href={`mailto:${settings.contact_email}`} class="footer-contact-link">
                  <svg class="footer-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                    <polyline points="22,6 12,13 2,6"/>
                  </svg>
                  {settings.contact_email}
                </a>
              </li>
            )}
            {settings.contact_phone && (
              <li>
                <a href={`tel:${settings.contact_phone.replace(/\s/g, '')}`} class="footer-contact-link">
                  <svg class="footer-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
                  </svg>
                  {settings.contact_phone}
                </a>
              </li>
            )}
            {settings.contact_address && (
              <li class="footer-address">
                <svg class="footer-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
                  <circle cx="12" cy="10" r="3"/>
                </svg>
                <span set:html={settings.contact_address.replace(/\n/g, '<br>')} />
              </li>
            )}
          </ul>
        </div>
      )}

      {settings?.social_links && settings.social_links.length > 0 && (
        <div class="footer-social">
          <h4 class="footer-nav-title">Volg ons</h4>
          <div class="footer-social-links">
            {settings.social_links.map((social) => (
              <a
                href={social.url}
                target="_blank"
                rel="noopener noreferrer"
                class="footer-social-link"
                aria-label={social.name}
                title={social.name}
                set:html={getSocialIcon(social.icon, social.name)}
              />
            ))}
          </div>
        </div>
      )}
    </div>

    <div class="footer-bottom">
      <p class="footer-copyright">
        {settings?.copyright_text || `© ${new Date().getFullYear()} ${settings?.site_name || 'Mijn Website'}. Alle rechten voorbehouden.`}
      </p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: #1f2937;
    color: #d1d5db;
    padding: 4rem 0 0;
    margin-top: auto;
  }

  .footer-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .footer-main {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 3rem;
    padding-bottom: 3rem;
    border-bottom: 1px solid #374151;
  }

  .footer-brand {
    grid-column: span 1;
  }

  @media (min-width: 768px) {
    .footer-brand {
      grid-column: span 2;
    }

    .footer-main {
      grid-template-columns: 2fr 1fr 1fr 1fr;
    }
  }

  .footer-logo {
    height: 40px;
    width: auto;
    object-fit: contain;
    filter: brightness(0) invert(1);
    margin-bottom: 1rem;
  }

  .footer-site-name {
    font-size: 1.5rem;
    font-weight: 700;
    color: white;
    display: block;
    margin-bottom: 1rem;
  }

  .footer-text {
    font-size: 0.95rem;
    line-height: 1.7;
    color: #9ca3af;
    max-width: 400px;
  }

  .footer-text :global(p) {
    margin: 0 0 0.5rem;
  }

  .footer-nav-title {
    font-size: 0.9rem;
    font-weight: 600;
    color: white;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin: 0 0 1.25rem;
  }

  .footer-menu {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .footer-menu-item {
    margin-bottom: 0.75rem;
  }

  .footer-menu-link {
    color: #9ca3af;
    text-decoration: none;
    font-size: 0.95rem;
    transition: color 0.15s;
  }

  .footer-menu-link:hover {
    color: white;
  }

  .footer-contact-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .footer-contact-list li {
    margin-bottom: 0.75rem;
  }

  .footer-contact-link {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: #9ca3af;
    text-decoration: none;
    font-size: 0.95rem;
    transition: color 0.15s;
  }

  .footer-contact-link:hover {
    color: white;
  }

  .footer-address {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    color: #9ca3af;
    font-size: 0.95rem;
    line-height: 1.5;
  }

  .footer-icon {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .footer-social-links {
    display: flex;
    gap: 1rem;
  }

  .footer-social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    background: #374151;
    border-radius: 50%;
    color: #d1d5db;
    transition: background-color 0.15s, color 0.15s;
  }

  .footer-social-link:hover {
    background: #6644ff;
    color: white;
  }

  .footer-social-link :global(svg) {
    width: 20px;
    height: 20px;
  }

  .footer-social-link :global(.social-letter) {
    font-size: 16px;
    font-weight: 600;
    line-height: 1;
  }

  .footer-bottom {
    padding: 1.5rem 0;
    text-align: center;
  }

  .footer-copyright {
    margin: 0;
    font-size: 0.875rem;
    color: #6b7280;
  }

  @media (max-width: 767px) {
    .footer {
      padding: 3rem 0 0;
    }

    .footer-main {
      gap: 2rem;
    }

    .footer-brand {
      text-align: center;
    }

    .footer-text {
      max-width: none;
    }
  }
</style>
